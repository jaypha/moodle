<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="report/taskstats/db" VERSION="20260324" COMMENT="XMLDB file for Moodle report/taskstats"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd"
>
    <TABLES>
        <TABLE NAME="report_taskstats_stats" COMMENT="Duration log of tasks.">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="type" TYPE="int" LENGTH="4" NOTNULL="true" SEQUENCE="false" COMMENT="The type of task. Scheduled task = 0; Adhoc task = 1."/>
                <FIELD NAME="component" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="classname" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="n" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Number of values"/>
                <FIELD NAME="sumduration" TYPE="float" LENGTH="20" DECIMALS="10" NOTNULL="false" SEQUENCE="false" COMMENT="Sum of the task durations"/>
                <FIELD NAME="mean" TYPE="float" LENGTH="20" DECIMALS="10" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="ssd" TYPE="float" LENGTH="20" DECIMALS="10" NOTNULL="false" SEQUENCE="false" COMMENT="Sum of squared deviations"/>
                <FIELD NAME="sd" TYPE="float" LENGTH="20" DECIMALS="10" NOTNULL="false" SEQUENCE="false" COMMENT="Standard deviation"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="classname" UNIQUE="true" FIELDS="classname"/>
            </INDEXES>
        </TABLE>

    </TABLES>
</XMLDB>
